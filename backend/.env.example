PORT=5000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

PGHOST=localhost
PGPORT=5433
PGDATABASE=vendorbridge
PGUSER=postgres
PGPASSWORD=your_postgres_password

# Alternative single URL format. Encode special characters like @ as %40.
# DATABASE_URL=postgresql://postgres:password@localhost:5433/vendorbridge

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
